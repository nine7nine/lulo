[Unit]
Description=Lulo privileged system daemon
Documentation=man:systemd.service(5)
After=local-fs.target

[Service]
Type=simple
ExecStart=@EXEC_START@
WorkingDirectory=@WORKDIR@
ExecStartPre=-/usr/bin/rm -f /run/lulod-system.sock
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
